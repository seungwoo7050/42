FROM alpine:3.18

# https://docs.openssl.org/master/man1/openssl-req/
RUN apk add --no-cache nginx openssl dumb-init && \
    mkdir -p /etc/ssl/private /etc/ssl/certs /run/nginx && \
    openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
    -subj "/C=KR/ST=Gyeonggi/L=Yongin/O=42Seoul/OU=Dev/CN=seungwok" \
    -keyout /etc/ssl/private/nginx-selfsigned.key \
    -out /etc/ssl/certs/nginx-selfsigned.crt && \    
    openssl dhparam -out /etc/nginx/dhparam.pem 2048
    # DH 매개변수 설정은 TLS 보안을 강화하는데 중요하지만 필수 과정은 아니다. 단, 권장되는 과정이다.
    # 매개변수 파일을 생성하고, Nginx 설정 파일에서 매개 변수를 사용하도록 설정해야 한다.

COPY ./conf/nginx.conf /etc/nginx/nginx.conf

EXPOSE 80 443

ENTRYPOINT ["/usr/bin/dumb-init", "--"]

CMD ["nginx", "-g", "daemon off;"]




############################################################################################################
# 1. HTTPS 통신의 구조
# HTTPS는 기본적으로 3가지 주요 단계를 거쳐 이루어진다.
# 1.1. TCP 핸드셰이크
# 클라이언트(예: 웹 브라우저)와 서버 간의 통신이 시작되면, 가장 먼저 TCP(전송 제어 프로토콜) 핸드셰이크가 이루어진다. 
# 이는 HTTPS가 아닌 모든 HTTP 통신에서도 동일하게 이루어지는 과정이다. 
# TCP 핸드셰이크는 다음과 같이 이루어집니다:
# * 클라이언트가 SYN 패킷을 서버로 전송(연결 요청을 알립니다).
# * 서버가 SYN-ACK 패킷을 클라이언트로 전송(연결 요청을 승인합니다).
# * 클라이언트가 ACK 패킷을 서버로 전송(연결을 확정합니다).
# 이 과정을 통해 두 장치 간에 신뢰할 수 있는 연결이 설정된다.
# 1.2. SSL/TLS 핸드셰이크
# TCP 핸드셰이크가 완료된 후, SSL/TLS 핸드셰이크가 이루어져 안전한 통신 채널을 구축한다. 이 과정은 다음 단계로 이루어진다:
# * 클라이언트 헬로(Client Hello): 클라이언트가 서버에 지원하는 암호화 방법, TLS 버전 등을 제안한다.
# * 서버 헬로(Server Hello): 서버가 클라이언트의 제안을 바탕으로 사용할 암호화 방법, TLS 버전 등을 선택하고, 서버의 인증서를 클라이언트에게 전송한다.
# * 서버 인증서 확인: 클라이언트는 서버가 제공한 인증서를 신뢰할 수 있는 CA(인증 기관)에서 발급한 것인지 확인한다. 클라이언트는 또한 서버의 공개 키를 사용하여 서버와 안전한 연결을 설정한다.
# * 프리마스터 시크릿 교환: 클라이언트와 서버는 프리마스터 시크릿이라는 암호화 키를 교환하며, 이는 대칭 키 암호화에 사용된다.
# * 세션 키 생성: 클라이언트와 서버는 프리마스터 시크릿을 기반으로 대칭 암호화에 사용할 세션 키를 생성한다.
# * 암호화된 세션 시작: 이후의 모든 통신은 이 세션 키를 사용해 암호화된다.
# 1.3. HTTP 요청 및 응답
# SSL/TLS 핸드셰이크가 완료되면, 클라이언트는 HTTPS를 통해 서버에 안전하게 HTTP 요청을 보낼 수 있게 된다. 이 요청과 응답은 모두 암호화된 채널을 통해 전달된다.

# 2. 인증서의 필요성과 역할
# 2.1. 인증서의 필요성
# 서버 쪽 인프라를 구성할 때 인증서를 발급받아야 하는 이유는 클라이언트에게 서버의 신뢰성을 증명하고, 중간자 공격(MITM)을 방지하기 위함이다. HTTPS의 근본적인 목표는 데이터의 무결성, 기밀성, 그리고 인증성을 보장하는 것.
# 인증: 클라이언트가 서버와 통신할 때, 서버가 신뢰할 수 있는 서버인지 확인해야 합니다. 이를 위해 서버는 인증서를 사용해 자신을 증명합니다.
# 암호화: 클라이언트와 서버 간의 데이터가 암호화되지 않은 상태로 전송되면, 제3자가 데이터를 가로채거나 수정할 수 있습니다. 인증서를 통해 설정된 SSL/TLS 암호화는 이를 방지합니다.

# 2.2. 인증서 발급 및 사용
# CSR 생성 (Certificate Signing Request): 서버 관리자는 서버의 공개 키와 서버의 도메인 정보를 포함한 CSR을 생성.
# 인증 기관(CA)에 제출: 이 CSR을 신뢰할 수 있는 CA에 제출.
# 인증서 발급: CA는 서버의 도메인 소유권을 확인한 후, 서버의 공개 키와 도메인 정보를 포함하는 디지털 인증서를 발급.
# 서버에 설치: 서버 관리자는 이 인증서를 서버에 설치하고, 클라이언트가 서버에 접근할 때 이를 제공.
# 2.3. 인증서 사용 과정
# 서버에 설치된 인증서는 SSL/TLS 핸드셰이크 과정에서 클라이언트에게 제공. 클라이언트는 이 인증서를 확인하여 서버의 신뢰성을 판단합니다. 만약 클라이언트가 인증서를 신뢰할 수 없거나, 인증서가 만료되었거나, 잘못된 도메인에 사용된다면, 클라이언트는 경고 메시지를 표시하고 연결을 차단할 수 있다.

## openssl 명령어
# req: CSR(Certificate Signing Request)을 생성하기 위해 사용되는 OpenSSL 명령어.
# -x509: CSR 대신 직접 인증서를 생성하는 옵션.
# -nodes: 비밀 키를 암호화 없이 평문으로 저장하는 옵션, 서버가 비밀 키를 사용할 때마다 암호를 입력할 필요가 없다.
# 개발 및 테스트 목적으로만 사용해야 하며, 실제 운영 환경에서는 사용하지 않는 것이 좋다.
# -days: 인증서의 유효 기간을 설정하는 옵션.
# -newkey rsa:2048: RSA 알고리즘을 사용하고, 2048비트의 키를 생성하는 옵션. 2048비트는 안전한 암호화 강도를 제공하는 표준 비트 길이.
# -subj: 인증서에 포함될 정보를 설정하는 옵션. 이메일 주소, 조직명, 도시, 주, 국가 등의 정보를 포함할 수 있다.
# 이 옵션을 사용하지 않으면 입력을 요청하는 프롬프트가 표시된다. 즉, 자동화 환경에서는 이 옵션을 사용하는 것이 좋다.

# 특정 도메인에 특정 프로토콜을 사용하여 연결 시도하기
# openssl s_client -connect domainname.com:443 -tls1_2(프로토콜)