CC = cc 
CFLAGS = -Wall -Wextra -Werror # -fsanitize=thread

NAME = philo

SRCS = main.c parsing.c iter.c fork.c life.c utils.c
OBJS = $(addprefix $(OBJS_DIR)/, $(SRCS:.c=.o))
OBJS_DIR = obj

all: $(NAME)

$(NAME): $(OBJS_DIR) $(OBJS)
	$(CC) $(CFLAGS) $(OBJS) -o $(NAME)

$(OBJS_DIR)/%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

$(OBJS_DIR):
	mkdir -p $(OBJS_DIR)
# -p옵션: 동일한 이름의 디렉토리가 이미 존재한다면 명령어를 실행하지 않고 무시한다.

clean:
	rm -rf $(OBJS_DIR)

fclean: clean
	rm -f $(NAME)

re: fclean all

.PHONY : all clean fclean re

##### 자동변수
# $@: 타겟 이름
# $*: 확장자를 제외한 타겟 이름
# $?: 목표 파일 보다 더 최근에 갱신된 파일 이름
# $^: 현재 타겟에 종속된 대상들의 전체 목록
# $<: 종속 항목중 첫번째 파일 이름

##### 문법
# $(addsuffix 접미사, 문자열) ex) $(addsuffix .c, memo main) => memo.c main.c
# $(addprefix 접두어, 문자열) ex) $(addprefix src/, memo main) => src/memo src/main
# $(shell shell command) ex) $(shell ls *.c) => shell 명령에 대한 결과가 변수에 들어감
# $(subst 찾을 문자, 변경할 문자, 대상 문자) => "대상문자"에서 "찾을 문자"를 "변경할 문자"로 변경해 준다.
# $(patsubst 찾을 패턴, 변경할 패턴, 대상 문자) => subst와 기능은 동일하나 확장자를 바꿀 때 사용함.
# $(strip 대상문자) => 대상문자에서 모든 공백을 1칸으로 줄인다. 여백이 많아도 모두 1칸이 된다.
# $(filter 찾을 문자, 대상 문자) => 대상문자에서 찾을 문자를 포함한 문자들을 찾아서 저장한다.
# $(filter-out 찾을 문자, 대상 문자) => filter와 반대로 찾을 문자가 있는 경우를 제외하고 저장한다.
# $(join 원본 문자, 붙일 문자) => 월본 문자와 붙일 문자를 붙여서 한 문자로 만든다.
# $(dir 대상 문자) => 대상 문자에서 파일 문자를 제외한 경로명만 추출한다.
# $(notdir 대상 문자) => 대상 문자에서 파일명만 추출한다.
# $(basename 대상 문자) => 대상 문자에서 확장자를 제외한 문자를 알려준다.

# ##### Philosophers with threads and mutexes #####

# ##### 구현 사항 요약 #####
# 철학자의 수와 포크의 수는 같다.
# 포크는 각각의 뮤텍스를 사용하여 보호하여야한다.
# 철학자는 두 개의 포크를 사용하여야만 식사할 수 있다.

# 인자
# 철학자 수, 수명, 식사시간, 자는시간, [식사횟수] ([]는 선택옵션)

# ##### 사용가능함수 #####

# <stdio.h>
# printf

# <stdlib.h>
# memset, malloc, free

# <unistd.h>
# usleep, write

# <sys/time.h>
# gettimeofday: 현재 시간과 날짜를 초 단위로 가져오는 함수.
# int gettimeofday(struct timeval *tv, struct timezone *tz);

# struct timeval {
#     time_t  tv_sec;     // 1970년 1월 1일 00:00:00 UTC부터의 경과 시간을 초로 나타낸다.
#     time_t  tv_usec;    // tv_sec의 초 단위 이하 부분을 마이크로초로 나타낸다.
# }; // 초와 마이크로초의 정밀한 시간정보를 얻는데 주로 사용.

# struct timezone {
#     int tz_minuteswest; // UTC에서 서부로부터 떨어진 시간 (분)
#     int tz_dsttime;     // 일괄/표준시간 여부 (0 또는 1)
# }; // 거의 사용되지 않으며 'gettimeofday' 함수 호출 시 두번 째 인자를 NULL로 전달하여 타임존 정보를 무시하고 사용. 

# <pthread.h>
# pthread_creat: 새로운 쓰레드를 생성하는 함수.
# int pthread_create(pthread_t *thread, const pthread_attr_t *attr, void *(*start_routine)(void *), void *arg);
# pthread_t 구조체에 생성된 쓰레드의 ID가 저장됨.
# start_routine은 쓰레드가 시작될 때 실행되는 함수.

# pthread_detach: 쓰레드를 분리하여 쓰레드가 종료될 때 자동으로 자원을 회수함.
# int pthread_detach(pthread_t thread);

# pthread_join: 특정 쓰레드의 종료를 기다림.
# int pthread_join(pthread_t thread, void **retval);
# retval에는 쓰레드의 종료 값을 저장할 포인터를 전달할 수 있다.

# pthread_mutex_init: 뮤텍스를 초기화하는 함수
# int pthread_mutex_inti(pthread_mutex_t *mutex, const pthread_mutexattr_t *attr);

# pthread_mutex_destroy: 뮤텍스를 해제하는 함수.
# int pthread_mutex_destroy(pthread_mutex_t *mutex);

# pthread_mutex_lock: 뮤텍스를 잠근다.
# int pthread_mutex_lock(pthread_mutex_t *mutex);
# 만약 뮤텍스가 이미 다른 스레드에 의해 잠겨져 있다면, 현재 스레드는 뮤텍스가 해제될 떄까지 대기.
# 성공적으로 뮤텍스를 잠그면 0, 오류가 발생하면 오류코드를 반환.

# pthread_mutex_unlock: 뮤텍스의 잠금을 해제.
# int pthread_mutex_unlock(pthread_mutex_t *mutex);
# 뮤텍스를 잠그고 있는 스레드가 있어한다.
# 만약 현재 스레드가 뮤텍스를 잠그지 않았거나, 이미 해제된 경우에는 정의되지 않은 동작이 발생할 수 있다.
# 성공적으로 뮤텍스를 해제하면 0을 반환하고, 오류가 발생하면 오류 코드를 반환.

# ##### 쓰레드와 뮤텍스 #####

# 쓰레드
# 프로세스 내에서 실행되는 독립적인 실행 흐름. 하나의 프로세스에 여러 개의 쓰레드가 존재할 수 있으며, 쓰레드들은 같은 프로세스 내의 메모리를 공유하면서 실행된다.
# 쓰레드는 실행 흐름을 나타내기 위한 추상적인 개념으로서, 언어나 라이브러리에 따라 구현이 달라질 수 있다.

# 쓰레드 사용단계

# 1. 쓰레드 생성
# 'pthread_t'자료형을 사용하여 쓰레드를 선언하고, 'pthread_create'함수를 호출하여 쓰레드를 생성한다.

# 2. 쓰레드 동기화를 위한 뮤텍스 초기화
# 'pthread_mutex_t'자료형을 사용하여 뮤텍스를 선언하고, 'PTHREAD_MUTEX_INITIALIZER'매크로를 사용하여 정적 초기화합니다.
#	* 쓰레드 동기화: 멀티 스레드 환경에서 다수의 스레드가 공유 자원에 동시에 접근할 때 데이터 일관성과 실행의 안정성을 유지하기위한 메커니즘.

# 3. 쓰레드 종료 및 뮤텍스 해제
# 'pthread_join'함수를 사용하여 쓰레드가 종료될 떄까지 기다리고, 뮤텍스를 더 이상 사용하지 않을 때
# 'pthread_mutex_destroy'함수로 뮤텍스를 해제합니다.


# 뮤텍스
# 상호 배제(Mutual Exclusion)를 위한 동기화 메커니즘으로서 여러 쓰레드가 공유 자원에 접근할 때, 뮤텍스는 한 번에 하나의 쓰레드만 해당 자원에 접근하도록 보장하여 데이터의 일관성을 유지한다.
# 특정 자료형을 갖지 않는 개념적인 개체이다. 하지만 POSIX('pthread')에서는 'pthread_mutex_t'와 같이 특정 자료형을 사용하여 뮤텍스를 표현한다.

# 뮤텍스의 사용단계

# 1. 뮤텍스 초기화:
# 'pthread_mutex_t'와 같은 뮤텍스 자료형을 선언하고,
# 'pthread_mutex_init'함수를 사용하여 초기화한다.

# 2. 임계 영역 보호:
# 공유 자원에 접근하는 코드를 '임계 영역'이라 한다. 해당 임계영역에 진입하기 전에
# 'pthread_mutex_lock'함수로 뮤텍스를 잠그고, 임계 영역을 빠져나올 때에는
# 'pthread_mutex_unlock'함수로 뮤텍스를 해제합니다.
# 뮤텍스 변수 하나하나가 각각의 열쇠가 하나뿐인 자물쇠라고 생각하면 이해에 큰 도움이 된다.

# 3. 뮤텍스 해제:
# 뮤텍스를 더 이상 사용하지 않을 때, 'pthread_mutex_destroy'함수를 호출하여 뮤텍스를 해제한다.

# 추가) 사용 시점:
# 뮤텍스 초기화와 해제의 시점은 정해져있는 것이 아니기에 사용자가 적절한 시점에 초기화하고 해제하면 된다.

# 추가) 사용 방식
# 뮤텍스(Mutex)는 주로 락(lock)과 언락(unlock) 사이의 코드 블록 내에서의 자원에 대한 접근을 보호하는 데 사용.
# 따라서 락과 언락으로 둘러싸인 코드 블록 사이에서의 공유 자원에 대한 접근이 동기화되어, 여러 스레드가 동시에 해당 자원에 접근하지 못하도록 한다.
# 뮤텍스 락 함수에 전달되는 인자는 특정 뮤텍스 객체를 나타낸다.
# 즉, 어떤 자원이나 코드 블록을 뮤텍스로 보호하기 위해 해당 뮤텍스 객체를 사용하는 것.
# 이 뮤텍스 객체는 pthread_mutex_t 자료형으로 선언되고 초기화된 변수.

# 뮤텍스의 초기화방식

# 1. 동적 초기화:
# pthread_mutex_t mutex;
# pthread_mutex_init(&mutex, NULL);

# 'pthread_mutex_init'함수를 호출하여 동적으로 초기화 하는 방법.

# 2. 정적 초기화:
# pthread_mutex_t mutex = PTHREAD_MUTEX_INITIALIZER;

# 'PTHREAD_MUTEX_INITIALIZER' 매크로를 사용하여 정적으로 초기화하는 방법.

# 차이점:
# 정적 초기화 할시 추가적인 초기화 함수를 호출할 필요없이 간결한 코드를 유지할 수 있다.
# 단, 정적으로 초기화된 뮤텍스는 나중에 소멸 함수를 호출하지 않고 바로 사용이 종료되면 안전하지 않을 수 있기에
# 동적 초기화를 사용하여 명시적으로 초기화와 해체를 하는 것이 더 안전한 방법이다.

# 데드락의 요소

# 1. 상호 배제:
# 자원은 동시에 여러 프로세스에 의해서 사용될 수 없다.

# 2. 보유 및 대기:
# 프로세스는 최소한 하나의 자원을 보유하고 있으면서 동시에 다른 자원을 기다린다.
# 이로 인해 한 프로세스가 자원을 보유하면서 다른 프로세스가 필요로 하는 자원을 점유하고있는 상황이 발생할 수 있다.

# 3. 비선점:
# 다른 프로세스가 보유한 자원을 강제로 빼앗을 수 없다.

# 4. 순환 대기:
# 프로세스 집합에서 각 프로세스는 순환적으로 다음 프로세스가 필요로 하는 자원을 보유하고 있어야 한다.
# 이렇게 되면 사이클이 형성되어 대기 상태가 뭏나정으로 이어질 수 있다.

# 4가지 조건이 동시에 성립할 때 데드락이 발생한다.

# 컨텍스트 스위칭

# 컴퓨터 시스템에서 실행중인 프로세스나 스레드의 상태를 저장하고 다른 프로세스나 스레드의 상태를 불러와 실행하는 과정.
# 컨텍스트 스위칭은 프로세스 또는 스레드의 상태를 저장하고 복원하는 데 많은 비용이 들기 때문에 효율적으로 관리되어야 한다.
# 운영 체제는 각 프로세스의 상태를 저장하는데 필요한 정보를 컨텍스트에 저장하고, 스케줄링 알고리즘을 통해 어떤 프로세스가 다음에 실행될지를 결정한다.
# 컨텍스트 스위칭은 시스템의 성능에 영향을 미치는 중요한 요소 중 하나이므로 최적화가 필요한 작업이다.

# 1. 시분할 시스템:
# 시분할 시스템에서는 CPU의 시간을 여러 프로세스에게 분할하여 각 프로세스가 동시에 실행되는 것처럼 보이게 한다.
# 이를 위해 일정 시간마다 컨텍스트 스위칭이 발생하여 현재 실행 중인 프로세스의 상태를 저장하고 다음으로 실행할 프로세스의 상태를 불러온다.

# 2. 인터럽트:
# 하드웨어 인터럽트나 소프트웨어 인터럽트가 발생하면 현재 실행 중인 프로세스나 스레드의 실행을 중단하고 인터럽트 서비스 루틴이나 핸들러를 실행한다.
# 이때 컨텍스트 스위칭이 필요할 수 있다.

# 3. 다중 코어 시스템:
# 다중 코어 시스템에서는 여러 코어가 동시에 다른 프로세스나 스레드를 실행할 수 있다.
# 코어 간에는 프로세스의 상태를 전환하는 컨텍스트 스위칭이 필요하다.

# usleep과 컨텍스트 스위칭

# 직접적인 연관은 없다.
# 다만 자원의 효율적인 관리를 위하여 BusyWaiting을 피하는데 사용할 수 있다.

# usleep이 정확한 시간을 쉬지 못하는 이유

# 1. 컨텍스트 스위칭 오버헤드:
# usleep호출로 해당 스레드가 중지되고 다른 스레드가 실행되는 '컨텍스트 스위칭'에 있어서 오버헤드는 필연적이다.

# 2. 타이밍 정확도 한계:
# 운영체제적인 한계로 인한 오차

# 3. 스레드 스케줄링 변동성:
# 스레드가 얼마나 빨리 다시 스케줄링되느냐에 대한 변동성.

# 4. 다른 우선순위를 가진 스레드의 영향:
# 각각의 스레드들의 우선순위가 다른경우 usleep 대기중이던 스레드의 우선순위가 낮아 실행이 늦어지는 경우가 있다.